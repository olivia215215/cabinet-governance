      <section class="ai-panel">
        <h2>入口识别优先级</h2>
        <div class="priority-list">
          <span class="priority-item"><b>P0</b> manifest.json</span>
          <span class="priority-item"><b>P1</b> skill.yaml</span>
          <span class="priority-item"><b>P2</b> SKILL.md</span>
