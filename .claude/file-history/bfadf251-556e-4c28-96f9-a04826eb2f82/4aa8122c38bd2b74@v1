          <span class="priority-item"><b>P4</b> .skill/SKILL.md</span>
          <span class="priority-item"><b>P5</b> README.md</span>
        </div>
      </section>
    `;
  }
  return `
    <section class="ai-panel">
      <h2>导入来源</h2>
      <label>已上传文件<input value="${escapeAttr(state.importedFileName || "customer_service_qa.zip")}" readonly></label>
    </section>
  `;
}

function renderMarkdownPreview(skill) {
  const lines = String(skill.content || "").split("\n");
  const html = lines.map(line => {
    if (line.startsWith("# ")) return `<h1>${escapeHtml(line.slice(2))}</h1>`;
    if (line.startsWith("## ")) return `<h2>${escapeHtml(line.slice(3))}</h2>`;
    if (/^\d+\.\s/.test(line)) return `<p class="ordered-line">${escapeHtml(line)}</p>`;
    if (line.startsWith("- ")) return `<p class="bullet-line">${escapeHtml(line.slice(2))}</p>`;
    if (!line.trim()) return "";
    return `<p>${escapeHtml(line)}</p>`;
  }).join("");
  return `
    <h1>${escapeHtml(skill.name || "未命名技能")}</h1>
    <h2>技能说明</h2>
    <p>${escapeHtml(skill.description)}</p>
    ${html}
  `;
}

function draftForMode(mode) {
  if (mode === "在线编写") return {
    ...createSkillFromNaturalLanguage("客户投诉处理"),
    name: "客户投诉处理 Skill",
    skillId: "complaint_handling_skill",
    source: "在线编写",
    description: "根据投诉内容判断问题类型、优先级和处理流程。",
    content: `/when_to_use
当用户需要处理客户投诉、判断优先级或生成处理建议时使用。

/input
required:
  - complaint: 客户投诉内容

/output
format: markdown

/constraints
- 不得承诺无法兑现的赔付或处理结果`
  };
  if (mode === "GitLab 拉取") return {
    ...createSkillFromNaturalLanguage("政策问答"),
    name: "Policy QA Skill",
    skillId: "policy_qa_skill_draft",
    source: "代码仓库拉取",
    description: "从 brclaw/skills/policy-qa 仓库识别出的政策问答 Skill。",
    assets: ["manifest.json", "SKILL.md", "references/sources.json"]
  };
  return {
    ...createSkillFromNaturalLanguage("导入技能包"),
    name: state.importedFileName ? `${state.importedFileName.replace(/\.[^.]+$/, "")} Skill` : "导入技能草稿",
    skillId: state.importedFileName ? `${state.importedFileName.replace(/\.[^.]+$/, "").toLowerCase().replace(/[^a-z0-9_-]+/g, "_")}_skill` : "imported_skill_draft",
    source: "导入技能包",
    description: `从 ${state.importedFileName || "customer_service_qa.zip"} 解析出的标准技能包。`,
    assets: ["manifest.json", "SKILL.md", "schemas/input.schema.json", "schemas/output.schema.json"]
  };
}

