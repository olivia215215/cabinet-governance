function loadSkills() {
  const saved = localStorage.getItem(storageKey);
  const skills = saved ? JSON.parse(saved) : seedSkills;
  // Migrate legacy skills (without files) to the new files-based format
  skills.forEach(skill => {
    if (!skill.files) {
      skill.files = {};
      const assets = skill.assets || [];
      if (assets.length > 0) {
        for (const asset of assets) {
          skill.files[asset] = asset === "SKILL.md" ? (skill.content || "") : bundleFileTemplate(asset);
        }
      } else {
        skill.files["SKILL.md"] = skill.content || "";
      }
      if (!skill.files["SKILL.md"]) {
        skill.files["SKILL.md"] = skill.content || "";
      }
      skill.assets = Object.keys(skill.files);
    }
  });
  return skills;
}

function saveSkills() {
  localStorage.setItem(storageKey, JSON.stringify(state.skills));
