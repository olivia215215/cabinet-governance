  grid-template-columns: repeat(4, minmax(0, 1fr));
}
.publish-logs-table.data-table > div {
  grid-template-columns: repeat(5, minmax(0, 1fr));
}
.refs-table.data-table > div {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}
.logs-table.data-table > div {
  grid-template-columns: repeat(8, minmax(0, 1fr));
  font-size: 12px;
}

@media (max-width: 1180px) {
  .logs-table.data-table > div {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
}

/* ---- New file modal ---- */
.new-file-modal {
  width: min(420px, calc(100vw - 40px));
  border: 0;
  border-radius: 14px;
  background: #fff;
  box-shadow: 0 24px 68px rgba(15, 23, 42, .26);
  padding: 28px;
}

.new-file-head {
  margin-bottom: 20px;
}

.new-file-head h2 {
  margin: 0 0 6px;
  font-size: 18px;
  font-weight: 650;
}

.new-file-head p {
  margin: 0;
  color: var(--muted);
  font-size: 13px;
}

.new-file-body {
  display: grid;
  gap: 16px;
}

.new-file-body label span {
  display: block;
  margin-bottom: 6px;
  color: #344054;
  font-size: 13px;
  font-weight: 560;
}

.new-file-body input {
  min-height: 42px;
  border: 1px solid #d9dee8;
  border-radius: 8px;
  font-size: 14px;
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
}

.new-file-quick {
  display: grid;
  gap: 8px;
}

.new-file-quick > span {
  color: #667085;
  font-size: 12px;
}

.quick-ext-list {
  display: flex;
  gap: 8px;
}

.quick-ext {
  min-height: 32px;
  padding: 0 14px;
  border: 1px solid #dde2eb;
  border-radius: 8px;
  background: #fff;
  color: #344054;
  font-size: 13px;
  font-weight: 560;
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
}

.quick-ext:hover {
  border-color: var(--blue);
  color: var(--blue);
  background: var(--blue-soft);
}

.new-file-error {
  margin: 0;
  color: var(--red);
  font-size: 12px;
  padding: 6px 10px;
  border-radius: 6px;
  background: #fff1f2;
}

.new-file-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  margin-top: 24px;
  padding-top: 16px;
  border-top: 1px solid #edf0f5;
}

.new-file-footer button {
  min-width: 80px;
  min-height: 40px;
  border-radius: 8px;
  font-weight: 560;
}
