  padding: 8px 10px;
  border-radius: var(--radius-sm);
  background: #fff1f2;
  border: 1px solid #fecaca;
}

.priority-list {
  display: grid;
  gap: 6px;
  padding: 8px 10px;
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  background: #f8fafc;
}

.priority-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: #344054;
}

.priority-item b {
  display: inline-block;
  min-width: 24px;
  padding: 1px 5px;
  border-radius: 4px;
  background: var(--blue-soft);
