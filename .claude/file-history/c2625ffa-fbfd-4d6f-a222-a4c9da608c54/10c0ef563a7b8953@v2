## 九、Docker 交付

```dockerfile
# Dockerfile
FROM node:22-alpine
WORKDIR /app
COPY . .
RUN npm ci && npm run build
EXPOSE 3000

# entrypoint: 自动执行数据库迁移+种子数据，然后启动服务
COPY docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh
ENTRYPOINT ["docker-entrypoint.sh"]
CMD ["npm", "start"]
```

```bash
# docker-entrypoint.sh — 启动即用，无需手动预处理
#!/bin/sh
set -e

# 等待 PostgreSQL 就绪 (最多等60秒，每2秒检查一次)
MAX_RETRIES=30
echo "Waiting for PostgreSQL..."
for i in $(seq 1 $MAX_RETRIES); do
  if npx prisma db execute --stdin > /dev/null 2>&1 <<< "SELECT 1"; then
    echo "PostgreSQL is ready."
    break
  fi
  if [ "$i" = "$MAX_RETRIES" ]; then
    echo "ERROR: PostgreSQL did not become ready within $((MAX_RETRIES * 2)) seconds."
    exit 1
  fi
  echo "  ...waiting ($i/$MAX_RETRIES)"
  sleep 2
done

# 数据库迁移
echo "Running database migrations..."
npx prisma migrate deploy

# 幂等 seed (seed脚本内使用 INSERT ... ON CONFLICT DO NOTHING 确保可重复执行)
echo "Seeding database..."
npx prisma db seed

echo "Starting application..."
exec "$@"
```

