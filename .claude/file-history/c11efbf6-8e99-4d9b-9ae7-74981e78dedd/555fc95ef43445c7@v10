"use client";

import { useState, useEffect } from "react";
import { getToday } from "@/lib/utils";
import { apiFetch } from "@/lib/api";
import { Star, Send } from "lucide-react";

export default function ReviewPage() {
  const [form, setForm] = useState({ score: 3, summary: "", highlight: "", lowlight: "", tomorrowGoal: "" });
  const [submitted, setSubmitted] = useState(false);
  const [aiFeedback, setAiFeedback] = useState("");
  const [todayReview, setTodayReview] = useState<any>(null);

  useEffect(() => {
    apiFetch(`/api/review?date=${getToday()}`)
      .then((data) => {
        if (data && data.id) {
          setTodayReview(data);
          setForm({ score: data.score, summary: data.summary || "", highlight: data.highlight || "", lowlight: data.lowlight || "", tomorrowGoal: data.tomorrowGoal || "" });
          setAiFeedback(data.aiFeedback || "");
        }
      });
  }, []);

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault();
    const data = await apiFetch("/api/review", {
      method: "POST",
      body: JSON.stringify({ ...form, date: getToday() }),
    });
    setSubmitted(true);
    setTodayReview(data);

    const ai = await apiFetch("/api/insights", {
      method: "POST",
      body: JSON.stringify({ type: "review", data: form }),
    });
    setAiFeedback(ai.text || "");
  }

  return (
    <div className="max-w-2xl mx-auto space-y-6">
      <div>
        <h1 className="text-3xl font-bold tracking-tight">每日复盘</h1>
        <p className="text-sm text-muted-foreground mt-1">三省吾身，日日精进</p>
      </div>

      {todayReview && submitted ? (
        <div className="space-y-4">
          <div className="bg-card rounded-2xl border p-6 text-center">
            <p className="text-5xl mb-2">{["", "😔", "😐", "🙂", "😊", "🌟"][todayReview.score]}</p>
            <p className="text-lg font-bold">今日评分 {todayReview.score}/5</p>
            <p className="text-sm text-muted-foreground mt-2">{todayReview.summary}</p>
          </div>

          {aiFeedback && (
            <div className="bg-card rounded-2xl border p-6">
              <h2 className="font-semibold flex items-center gap-2 mb-3">
                <Star className="w-4 h-4 text-yellow-500" /> AI 教练点评
              </h2>
              <p className="text-sm leading-relaxed text-muted-foreground whitespace-pre-wrap">{aiFeedback}</p>
            </div>
          )}

          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div className="bg-card rounded-xl border p-4">
              <p className="text-xs text-muted-foreground mb-1">今日亮点</p>
              <p className="text-sm">{todayReview.highlight || "—"}</p>
            </div>
            <div className="bg-card rounded-xl border p-4">
              <p className="text-xs text-muted-foreground mb-1">待改进</p>
              <p className="text-sm">{todayReview.lowlight || "—"}</p>
            </div>
          </div>
        </div>
      ) : (
        <form onSubmit={handleSubmit} className="bg-card rounded-2xl border p-6 space-y-5">
          <div>
            <label className="text-sm font-medium">今日整体评分</label>
            <div className="flex gap-2 mt-2">
              {[1, 2, 3, 4, 5].map((s) => (
                <button key={s} type="button" onClick={() => setForm({ ...form, score: s })}
                  className={`w-12 h-12 rounded-xl text-2xl transition-all ${
                    form.score >= s ? "bg-yellow-100 border-yellow-400 scale-110" : "bg-muted border-transparent"
                  } border-2`}
                >
                  ⭐
                </button>
              ))}
            </div>
          </div>

          <div>
            <label className="text-sm font-medium">一句话总结</label>
            <input className="w-full mt-1 px-3 py-2.5 rounded-xl border bg-background text-sm outline-none focus:ring-2 focus:ring-primary/20" placeholder="今天过得怎么样？" value={form.summary} onChange={(e) => setForm({ ...form, summary: e.target.value })} />
          </div>

          <div>
            <label className="text-sm font-medium">今日亮点</label>
            <input className="w-full mt-1 px-3 py-2.5 rounded-xl border bg-background text-sm outline-none focus:ring-2 focus:ring-primary/20" placeholder="最值得骄傲的事" value={form.highlight} onChange={(e) => setForm({ ...form, highlight: e.target.value })} />
          </div>

          <div>
            <label className="text-sm font-medium">需要改进</label>
            <input className="w-full mt-1 px-3 py-2.5 rounded-xl border bg-background text-sm outline-none focus:ring-2 focus:ring-primary/20" placeholder="可以做得更好的地方" value={form.lowlight} onChange={(e) => setForm({ ...form, lowlight: e.target.value })} />
          </div>

          <div>
            <label className="text-sm font-medium">明日目标</label>
            <input className="w-full mt-1 px-3 py-2.5 rounded-xl border bg-background text-sm outline-none focus:ring-2 focus:ring-primary/20" placeholder="明天最重要的三件事" value={form.tomorrowGoal} onChange={(e) => setForm({ ...form, tomorrowGoal: e.target.value })} />
          </div>

          <button type="submit" className="w-full flex items-center justify-center gap-2 py-3 bg-primary text-primary-foreground rounded-xl font-medium hover:opacity-90 transition-opacity">
            <Send className="w-4 h-4" /> 提交复盘
          </button>
        </form>
      )}
    </div>
  );
}
