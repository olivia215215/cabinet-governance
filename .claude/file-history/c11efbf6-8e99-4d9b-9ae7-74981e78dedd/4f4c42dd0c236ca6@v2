"use client";

import { useState, useEffect } from "react";
import { formatDate, getToday, PRESET_DOMAINS } from "@/lib/utils";
import { CheckCircle2, Circle, Flame, Trophy, Target } from "lucide-react";

interface Habit {
  id: string;
  title: string;
  description: string | null;
  domainId: string;
  unit: string;
  targetValue: number;
  isActive: boolean;
  logs?: { date: string; completed: boolean; value: number }[];
}

export default function DashboardPage() {
  const [habits, setHabits] = useState<Habit[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    fetchHabits();
  }, []);

  async function fetchHabits() {
    const res = await fetch("/api/habits?date=" + getToday());
    const data = await res.json();
    setHabits(data);
    setLoading(false);
  }

  async function toggleHabit(habitId: string) {
    await fetch("/api/logs", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ habitId, date: getToday() }),
    });
    fetchHabits();
  }

  const completedCount = habits.filter(
    (h) => h.logs?.length && h.logs[0]?.completed
  ).length;
  const totalCount = habits.filter((h) => h.isActive).length;
  const progressPct = totalCount > 0 ? Math.round((completedCount / totalCount) * 100) : 0;

  if (loading) {
    return (
      <div className="flex items-center justify-center h-64 text-muted-foreground">
        加载中...
      </div>
    );
  }

  return (
    <div className="max-w-2xl mx-auto space-y-6">
      {/* Header */}
      <div>
        <p className="text-sm text-muted-foreground">{formatDate(new Date())}</p>
        <h1 className="text-3xl font-bold mt-1 tracking-tight">今日日课</h1>
      </div>

      {/* Progress Ring */}
      <div className="bg-card rounded-2xl border p-6 flex items-center gap-6">
        <div className="relative w-20 h-20 flex-shrink-0">
          <svg className="w-20 h-20 -rotate-90" viewBox="0 0 80 80">
            <circle cx="40" cy="40" r="34" fill="none" stroke="var(--border)" strokeWidth="6" />
            <circle
              cx="40" cy="40" r="34"
              fill="none" stroke="var(--primary)" strokeWidth="6"
              strokeLinecap="round"
              strokeDasharray={`${progressPct * 2.14} 214`}
            />
          </svg>
          <span className="absolute inset-0 flex items-center justify-center text-lg font-bold">
            {progressPct}%
          </span>
        </div>
        <div>
          <p className="text-2xl font-bold">{completedCount}/{totalCount}</p>
          <p className="text-sm text-muted-foreground">今日已完成</p>
          <div className="flex gap-2 mt-1 text-xs text-muted-foreground">
            <span className="flex items-center gap-1"><Flame className="w-3 h-3 text-orange-500" /> 连续 0 天</span>
          </div>
        </div>
      </div>

      {/* Habit List grouped by domain */}
      {PRESET_DOMAINS.map((domain) => {
        const domainHabits = habits.filter((h) => h.domainId === domain.name && h.isActive);
        if (domainHabits.length === 0) return null;
        return (
          <div key={domain.name}>
            <h2 className="text-sm font-medium text-muted-foreground mb-2 flex items-center gap-2">
              <span>{domain.icon}</span> {domain.name}
            </h2>
            <div className="space-y-1">
              {domainHabits.map((habit) => {
                const done = habit.logs?.length && habit.logs[0]?.completed;
                return (
                  <button
                    key={habit.id}
                    onClick={() => toggleHabit(habit.id)}
                    className={`w-full flex items-center gap-3 p-4 rounded-xl border transition-all text-left ${
                      done
                        ? "bg-muted border-border opacity-60"
                        : "bg-card hover:border-primary/30 hover:shadow-sm"
                    }`}
                  >
                    {done ? (
                      <CheckCircle2 className="w-6 h-6 text-success flex-shrink-0" />
                    ) : (
                      <Circle className="w-6 h-6 text-muted-foreground flex-shrink-0" />
                    )}
                    <div className="flex-1 min-w-0">
                      <p className={`font-medium ${done ? "line-through text-muted-foreground" : ""}`}>
                        {habit.title}
                      </p>
                      {habit.description && (
                        <p className="text-xs text-muted-foreground truncate">{habit.description}</p>
                      )}
                    </div>
                    <span className="text-xs text-muted-foreground">
                      {habit.targetValue}{habit.unit}
                    </span>
                  </button>
                );
              })}
            </div>
          </div>
        );
      })}

      {totalCount === 0 && (
        <div className="text-center py-12 text-muted-foreground">
          <Target className="w-12 h-12 mx-auto mb-3 opacity-30" />
          <p>还没有习惯</p>
          <p className="text-sm mt-1">去「习惯」页面添加你的第一个日课吧</p>
        </div>
      )}
    </div>
  );
}
