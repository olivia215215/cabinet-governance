export interface Goal {
  id: string;
  userId: string;
  title: string;
  description: string | null;
  startValue: number;
  targetValue: number;
  currentValue: number;
  unit: string;
  deadline: string | null;
  linkedHabitIds: string[];
  isArchived: boolean;
  createdAt: string;
  updatedAt: string;
}

export interface GoalLog {
  id: string;
  goalId: string;
  userId: string;
  previousValue: number;
  newValue: number;
  delta: number;
  note: string | null;
  createdAt: string;
}

