"use client";

import { useState, useEffect } from "react";
import { PRESET_DOMAINS } from "@/lib/utils";
import { Plus, Trash2, Edit3, GripVertical } from "lucide-react";

interface Habit {
  id: string;
  title: string;
  description: string | null;
  domainId: string;
  unit: string;
  targetValue: number;
  frequency: string;
  reminderTime: string | null;
  isActive: boolean;
}

export default function HabitsPage() {
  const [habits, setHabits] = useState<Habit[]>([]);
  const [loading, setLoading] = useState(true);
  const [showForm, setShowForm] = useState(false);
  const [editing, setEditing] = useState<Habit | null>(null);
  const [form, setForm] = useState({
    title: "", description: "", domainId: "健身", unit: "次",
    targetValue: 1, frequency: "daily", reminderTime: "",
  });

  useEffect(() => { fetchHabits(); }, []);

  async function fetchHabits() {
    const res = await fetch("/api/habits");
    setHabits(await res.json());
    setLoading(false);
  }

  function openNew() {
    setEditing(null);
    setForm({ title: "", description: "", domainId: "健身", unit: "次", targetValue: 1, frequency: "daily", reminderTime: "" });
    setShowForm(true);
  }

  function openEdit(h: Habit) {
    setEditing(h);
    setForm({ title: h.title, description: h.description || "", domainId: h.domainId, unit: h.unit, targetValue: h.targetValue, frequency: h.frequency, reminderTime: h.reminderTime || "" });
    setShowForm(true);
  }

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault();
    if (editing) {
      await fetch("/api/habits", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id: editing.id, ...form }),
      });
    } else {
      await fetch("/api/habits", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(form),
      });
    }
    setShowForm(false);
    fetchHabits();
  }

  async function deleteHabit(id: string) {
    await fetch("/api/habits", {
      method: "DELETE",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ id }),
    });
    fetchHabits();
  }

  async function toggleActive(id: string, current: boolean) {
    await fetch("/api/habits", {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ id, isActive: !current }),
    });
    fetchHabits();
  }

  if (loading) return <div className="flex items-center justify-center h-64 text-muted-foreground">加载中...</div>;

  return (
    <div className="max-w-2xl mx-auto space-y-6">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-3xl font-bold tracking-tight">习惯管理</h1>
          <p className="text-sm text-muted-foreground mt-1">管理你的每日修炼清单</p>
        </div>
        <button onClick={openNew} className="flex items-center gap-2 px-4 py-2.5 bg-primary text-primary-foreground rounded-xl text-sm font-medium hover:opacity-90 transition-opacity">
          <Plus className="w-4 h-4" /> 新增
        </button>
      </div>

      {PRESET_DOMAINS.map((domain) => {
        const domainHabits = habits.filter((h) => h.domainId === domain.name);
        return (
          <div key={domain.name}>
            <h2 className="text-sm font-medium text-muted-foreground mb-2 flex items-center gap-2">
              {domain.icon} {domain.name}
            </h2>
            <div className="space-y-1">
              {domainHabits.map((habit) => (
                <div
                  key={habit.id}
                  className={`flex items-center gap-3 p-4 rounded-xl border bg-card transition-all ${
                    !habit.isActive && "opacity-40"
                  }`}
                >
                  <div className="flex-1 min-w-0">
                    <p className={`font-medium ${!habit.isActive && "line-through"}`}>{habit.title}</p>
                    {habit.description && <p className="text-xs text-muted-foreground">{habit.description}</p>}
                    <div className="flex gap-3 mt-1 text-xs text-muted-foreground">
                      <span>{habit.frequency === "daily" ? "每日" : habit.frequency}</span>
                      <span>目标 {habit.targetValue}{habit.unit}</span>
                    </div>
                  </div>
                  <div className="flex gap-1">
                    <button onClick={() => toggleActive(habit.id, habit.isActive)} className={`p-2 rounded-lg text-xs ${habit.isActive ? "bg-muted" : "bg-success/10 text-success"}`}>
                      {habit.isActive ? "停用" : "启用"}
                    </button>
                    <button onClick={() => openEdit(habit)} className="p-2 rounded-lg hover:bg-muted">
                      <Edit3 className="w-4 h-4 text-muted-foreground" />
                    </button>
                    <button onClick={() => deleteHabit(habit.id)} className="p-2 rounded-lg hover:bg-red-50">
                      <Trash2 className="w-4 h-4 text-red-400" />
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}

      {habits.length === 0 && (
        <div className="text-center py-12 text-muted-foreground">
          <p>还没有习惯，点右上角「新增」开始</p>
        </div>
      )}

      {/* Form Modal */}
      {showForm && (
        <div className="fixed inset-0 bg-black/40 z-50 flex items-end md:items-center justify-center" onClick={() => setShowForm(false)}>
          <form
            onSubmit={handleSubmit}
            onClick={(e) => e.stopPropagation()}
            className="bg-card w-full max-w-lg rounded-t-2xl md:rounded-2xl p-6 space-y-4 shadow-xl max-h-[80vh] overflow-auto animate-slide-up"
          >
            <h2 className="text-lg font-bold">{editing ? "编辑习惯" : "新增习惯"}</h2>

            <div>
              <label className="text-sm font-medium">名称</label>
              <input className="w-full mt-1 px-3 py-2.5 rounded-xl border bg-background text-sm outline-none focus:ring-2 focus:ring-primary/20" placeholder="如：晨跑30分钟" value={form.title} onChange={(e) => setForm({ ...form, title: e.target.value })} required />
            </div>

            <div>
              <label className="text-sm font-medium">描述（可选）</label>
              <input className="w-full mt-1 px-3 py-2.5 rounded-xl border bg-background text-sm outline-none focus:ring-2 focus:ring-primary/20" placeholder="具体怎么做" value={form.description} onChange={(e) => setForm({ ...form, description: e.target.value })} />
            </div>

            <div className="grid grid-cols-2 gap-4">
              <div>
                <label className="text-sm font-medium">领域</label>
                <select className="w-full mt-1 px-3 py-2.5 rounded-xl border bg-background text-sm outline-none" value={form.domainId} onChange={(e) => setForm({ ...form, domainId: e.target.value })}>
                  {PRESET_DOMAINS.map((d) => <option key={d.name} value={d.name}>{d.icon} {d.name}</option>)}
                </select>
              </div>
              <div>
                <label className="text-sm font-medium">频率</label>
                <select className="w-full mt-1 px-3 py-2.5 rounded-xl border bg-background text-sm outline-none" value={form.frequency} onChange={(e) => setForm({ ...form, frequency: e.target.value })}>
                  <option value="daily">每日</option>
                  <option value="weekly">每周</option>
                  <option value="weekday">工作日</option>
                </select>
              </div>
            </div>

            <div className="grid grid-cols-2 gap-4">
              <div>
                <label className="text-sm font-medium">目标值</label>
                <input type="number" className="w-full mt-1 px-3 py-2.5 rounded-xl border bg-background text-sm outline-none" min={1} value={form.targetValue} onChange={(e) => setForm({ ...form, targetValue: parseInt(e.target.value) || 1 })} />
              </div>
              <div>
                <label className="text-sm font-medium">单位</label>
                <input className="w-full mt-1 px-3 py-2.5 rounded-xl border bg-background text-sm outline-none" placeholder="次/分钟/页" value={form.unit} onChange={(e) => setForm({ ...form, unit: e.target.value })} />
              </div>
            </div>

            <div className="flex gap-3 pt-2">
              <button type="button" onClick={() => setShowForm(false)} className="flex-1 py-2.5 rounded-xl border text-sm font-medium">取消</button>
              <button type="submit" className="flex-1 py-2.5 rounded-xl bg-primary text-primary-foreground text-sm font-medium">
                {editing ? "保存" : "添加"}
              </button>
            </div>
          </form>
        </div>
      )}
    </div>
  );
}
