import { View, Text, Picker } from "@tarojs/components";

interface ReminderCardProps {
  enabled: boolean;
  time: string;
  days: number[];
  onToggle: (value: boolean) => void;
  onTimeChange: (time: string) => void;
  onDayToggle: (day: number) => void;
}

const DAY_LABELS = ["一", "二", "三", "四", "五", "六", "日"];

export default function ReminderCard({
  enabled,
  time,
  days,
  onToggle,
  onTimeChange,
  onDayToggle,
}: ReminderCardProps) {
  return (
    <View className="card reminder-card">
      <View className="card-title-row">
        <Text className="card-title">打卡提醒</Text>
        <View
          className={`toggle ${enabled ? "active" : ""}`}
          onClick={() => onToggle(!enabled)}
        >
          <View className="toggle-knob" />
        </View>
      </View>

      {enabled && (
        <View className="reminder-options">
          <Picker
            mode="time"
            value={time}
            onChange={(e) => onTimeChange(e.detail.value)}
          >
            <View className="reminder-time-picker">
              <Text className="reminder-label">提醒时间</Text>
              <Text className="reminder-value">{time}</Text>
            </View>
          </Picker>

          <View className="reminder-days">
            <Text className="reminder-label">提醒日期</Text>
            <View className="day-buttons">
              {DAY_LABELS.map((label, i) => {
                const day = i + 1;
                const selected = days.includes(day);
                return (
                  <View
                    key={day}
                    className={`day-btn ${selected ? "selected" : ""}`}
                    onClick={() => onDayToggle(day)}
                  >
                    <Text>{label}</Text>
                  </View>
                );
              })}
            </View>
          </View>
        </View>
      )}
    </View>
  );
}
